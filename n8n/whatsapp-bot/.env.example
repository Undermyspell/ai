# Copy to .env and adjust. .env is gitignored.

PORT=8080

# Postgres (Stammtisch-Domänendaten liegen in DB "zumba")
DB_HOST=192.168.178.46
DB_PORT=5433
DB_NAME=zumba
DB_USER=n8n
DB_PASSWORD=n8n_password
DB_SSLMODE=disable

# Google Gemini (Absage/Zusage-Classifier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-3-flash-preview

# Wohin gehen erzeugte WhatsApp-Nachrichten? evolution | stdout | file
# Für lokale Tests ohne Evolution: stdout (in die Server-Logs) oder file.
OUTPUT_MODE=evolution
OUTPUT_FILE=output.txt

# Evolution API (WhatsApp senden) – nur relevant bei OUTPUT_MODE=evolution
# Staging im Cluster z.B.: EVOLUTION_URL=http://evolution-stage.pi.home
EVOLUTION_URL=http://localhost:8090
EVOLUTION_API_KEY=test_api_key
EVOLUTION_INSTANCE=whatsapp

# Zumba-WhatsApp-Gruppe (remoteJid) – nur Nachrichten aus dieser Gruppe werden klassifiziert
ZUMBA_GROUP_JID=491717868843-1443438520@g.us

# Zeitzone für die Donnerstag-Prüfung und das Tagesdatum
TZ=Europe/Berlin
